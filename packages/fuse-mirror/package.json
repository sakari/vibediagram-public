{
  "name": "@diagram/fuse-mirror",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "fuse-mirror": "./src/cli.ts"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "start": "tsx src/cli.ts",
    "test": "vitest run --exclude 'src/*integration.test.ts'",
    "test:check": "vitest run --exclude 'src/*integration.test.ts' --reporter dot --bail 1 --coverage",
    "test:integration": "LD_LIBRARY_PATH=$(dirname $(find ../../node_modules -name libfuse.so -path '*/linux-x64/*' 2>/dev/null | head -1)):$LD_LIBRARY_PATH vitest run src/integration.test.ts src/jazz-sync.integration.test.ts",
    "test:watch": "vitest --exclude 'src/*integration.test.ts'"
  },
  "dependencies": {
    "@diagram/jazz-schema": "workspace:^",
    "@diagram/ts-worker": "workspace:^",
    "commander": "^13.0.0",
    "jazz-tools": "^0.18.3",
    "cojson": "^0.18.3"
  },
  "optionalDependencies": {
    "fuse-native": "^2.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.0.0",
    "typescript": "^5.2.2",
    "vitest": "^3.0.0"
  }
}
