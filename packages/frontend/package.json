{
  "name": "@diagram/frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint src --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:check": "vitest run --reporter dot --bail 1 --coverage",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@diagram/diagram-view": "workspace:^",
    "@diagram/editor": "workspace:^",
    "@diagram/jazz-schema": "workspace:^",
    "@diagram/markdown-view": "workspace:^",
    "@diagram/sim-examples": "workspace:^",
    "@diagram/sim-model": "workspace:^",
    "@diagram/sim-worker": "workspace:^",
    "@visx/group": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "jazz-tools": "^0.18.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@diagram/ts-worker": "workspace:^",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^28.1.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vitest": "^3.0.0"
  }
}
